# ==============================================================================
# FreelanceFlow .gitignore
# Stack: React, Vite, Tailwind v4, Supabase
# ==============================================================================

# 1. Dependency Directories
node_modules/
.pnp
.pnp.js
credentials.js

# 2. Build Outputs & Artifacts
dist/
dist-ssr/
build/
*.tsbuildinfo

# 3. Environment Variables & Secrets (CRITICAL)
# Never commit your Supabase keys or database passwords
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.local

# 4. Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 5. Testing & Coverage
coverage/
.nyc_output

# 6. Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 7. IDEs and Editors
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
.vs/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# 8. Caches
.eslintcache
.vite/
.turbo/
.postman/
postman/
